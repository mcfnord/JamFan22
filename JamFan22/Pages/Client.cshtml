    function preventLineWrap() {
        const musicians = document.querySelectorAll('span.musician');
        
        musicians.forEach(span => {
            // Force inline-block so offsetHeight accurately reflects wrapped text lines
            span.style.display = 'inline-block';
            
            // Reset to 1em to recalculate properly (especially needed on window resize)
            let currentSize = 1.0;
            span.style.fontSize = currentSize + 'em';
            
            // A single line is typically ~20-25px tall. If it wraps, it jumps > 35px.
            // We shrink by 5% increments until it fits or hits our readability floor (0.65em).
            while (span.offsetHeight > 30 && currentSize > 0.65) {
                currentSize -= 0.05;
                span.style.fontSize = currentSize + 'em';
            }
        });
    }

    function runDOMDiagnostics(apiData) {
        let diagnosticLog = "";
        let hasErrors = false;

        apiData.forEach(server => {
            const serverId = getServerId(server);
            const serverEl = document.getElementById(serverId);
            
            if (!serverEl) return; 
            
            const clientsDiv = serverEl.querySelector('.server-clients');
            if (!clientsDiv) return;

            // Expected musicians from API
            const counts = {};
            const expectedIds = (server.clients || []).map(c => {
                const hashKey = (c.name || "") + (c.country || "");
                counts[hashKey] = (counts[hashKey] || 0);
                return getMusicianId(c, serverId, counts[hashKey]++);
            });
            
            // Actual musicians in DOM
            // Filter out elements currently animating out (maxHeight == '0px')
            const domNodes = Array.from(clientsDiv.querySelectorAll('.musician-container'))
                                  .filter(el => el.style.maxHeight !== '0px');
            
            const actualIds = domNodes.map(el => el.id);

            // Check for duplicates in DOM
            const domIdCounts = {};
            actualIds.forEach(id => {
                domIdCounts[id] = (domIdCounts[id] || 0) + 1;
            });

            let serverErrors = [];

            // A. Detect Duplicates in DOM
            for (const [id, count] of Object.entries(domIdCounts)) {
                if (count > 1) {
                    serverErrors.push(`DUPLICATE: ID ${id} appears ${count} times in DOM.`);
                }
            }

            // B. Detect Ghosts (In DOM but not in API)
            actualIds.forEach(id => {
                if (!expectedIds.includes(id)) {
                    serverErrors.push(`GHOST: ID ${id} is in DOM but missing from API.`);
                }
            });

            // C. Detect Missing (In API but not in DOM)
            expectedIds.forEach(id => {
                if (!actualIds.includes(id)) {
                    serverErrors.push(`MISSING: ID ${id} is in API but missing from DOM.`);
                }
            });

            if (serverErrors.length > 0) {
                hasErrors = true;
                diagnosticLog += `\n[SERVER: ${server.name} | ${serverId}]\n`;
                serverErrors.forEach(err => diagnosticLog += `  - ${err}\n`);
                diagnosticLog += `  API Expected (${expectedIds.length}): ${expectedIds.join(', ')}\n`;
                diagnosticLog += `  DOM Actual   (${actualIds.length}): ${actualIds.join(', ')}\n`;
            }
        });

        if (hasErrors) {
            console.warn("=== JAMFAN DOM DESYNC DETECTED ===\n" + diagnosticLog + "\n==================================");
        }
    }

    function updateServersList(data) {
        const container = document.getElementById("servers-table-container");
        if (!container) return;
        
        const sortedData = [...data].sort((a, b) => {
            const nameA = a.name ? a.name.toLowerCase() : "";
            const nameB = b.name ? b.name.toLowerCase() : "";
            return nameA.localeCompare(nameB);
        });

        let html = "<table><tr><th>Server<th>Server Address</tr>\n";
        sortedData.forEach(server => {
            if (server.name && server.serverIpAddress) {
                html += `<tr><td>${server.name}<td>${server.serverIpAddress}:${server.serverPort}</tr>\n`;
            }
        });
        html += "</table>\n";
        container.innerHTML = html;
    }

