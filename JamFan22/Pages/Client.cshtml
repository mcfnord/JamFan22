    function getSmartNations(server) {
        if (!server.clients || server.clients.length === 0) return "";
        
        const serverCountry = server.country || "";
        let iCountryless = 0;
        let itotalpeeps = server.clients.length;
        
        server.clients.forEach(who => {
            if (who.country === "World" || !who.country || who.country.length < 2) {
                iCountryless++;
            }
        });
        
        if (iCountryless / itotalpeeps >= 0.5) return "";
        
        let fNeeded = false;
        server.clients.forEach(who => {
            if (who.country && who.country.length > 1 && who.country !== serverCountry) {
                fNeeded = true;
            }
        });
        
        if (!fNeeded) return "";
        
        let smartNationsList = [];
        server.clients.forEach(who => {
            if (who.country && who.country.length > 1 && who.country !== "World") {
                if (!smartNationsList.includes(who.country)) {
                    smartNationsList.push(who.country);
                }
            }
        });
        
        let nationsStr = smartNationsList.join(" &middot; ");
        
        if (smartNationsList.length > 2) {
            nationsStr = nationsStr.replace(/United States/g, "USA");
            nationsStr = nationsStr.replace(/United Kingdom/g, "UK");
            nationsStr = nationsStr.replace(/Hong Kong/g, "HK");
        }
        
        if (smartNationsList.length > 3) {
            nationsStr = nationsStr.replace(/ &middot; /g, " ");
        }
        
        if (nationsStr === serverCountry) return "";
        
        return nationsStr;
    }

    function getInstrumentDisplay(instrument) {
        if (!instrument) return "";
        
        if (instrument === "Electric Guitar") return "⚡🎸";
        if (instrument === "Bass Guitar") return "<i>Bass</i> 🎸";
        if (instrument.toLowerCase().indexOf("guitar vocal") !== -1) return "🎸 <i>Vocal</i>";

        if (instrumentEmojis[instrument]) {
            return instrumentEmojis[instrument];
        }

        return `<i>${instrument}</i>`;
    }

    function getMusicianId(client) {
        return 'm-' + btoa(unescape(encodeURIComponent((client.name || '') + (client.country || '')))).replace(/=/g, '');
    }

    function getServerId(server) {
        return 's-' + server.serverIpAddress.replace(/\./g, '-') + '-' + server.serverPort;
    }

function ensureNoShrink(el) {
    if (!el) return;
    const inner = el.querySelector('.server-inner');
    if (!inner) return;
    
    // Change this from 32 to 14 so it matches the ResizeObserver math perfectly
    const contentHeight = inner.offsetHeight + 14; 
    const lockedHeight = parseFloat(el.dataset.lockedHeight) || 0;
    
    if (contentHeight > lockedHeight) {
        el.dataset.lockedHeight = contentHeight;
        el.style.minHeight = contentHeight + 'px';
    }
}

    function renderServerHeader(server) {
        let html = `<center>`;
        html += `<a href='https://jamulus.live/jamgroup-map.html?server=${server.serverIpAddress}:${server.serverPort}' target='_blank' style='position:absolute; right:5px; top:5px; z-index:10; text-decoration:none; font-size:1.5em; cursor:pointer; opacity:0; transition:opacity 0.2s;' onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0'">👀</a>`;
        
        if (server.name) html += `${server.name}<br>`;
        if (server.city) html += `<b>${server.city}</b><br>`;
        
        let cat = server.category || "";
        cat = cat.replace("Genre ", "").replace(" ", "&nbsp;");
        if (cat) html += `<font size='-1'>${cat}</font><br>`;
        
        if (server.newJamFlag) {
            html += `${server.newJamFlag}<br>`;
        }

        if (server.isNewServer) {
            html += `(New server.)<br>`;
        }
        
        if (server.listenHtml) {
            html += `${server.listenHtml}`;
        }
        
        html += `</center>`;
        return html;
    }

    function renderServerFooter(server) {
        let footerHtml = '';
        if (server.serverDurationHtml) {
            footerHtml += `<div>${server.serverDurationHtml}</div>`;
        }
        
        let byeHtml = '';
        if (server.leavers && server.leavers.length > 0) {
            byeHtml = `<div style="color:gray; font-size:0.7em;"><i>Bye ${server.leavers.join("&nbsp;&middot;&nbsp;")}</i></div>`;
        }

        let nationsHtml = '';
        let smartNations = (server.smartNations ? server.smartNations : getSmartNations(server));
        if (smartNations) {
            if (!navigator.userAgent.includes("Windows")) {
                smartNations = replaceCountry(smartNations);
            }
            nationsHtml = `<div style="font-size:0.7em; margin-top:0.5rem;">${smartNations}</div>`;
        }
        
        let soonHtml = '';
        if (server.soonNames && server.soonNames.length > 0) {
            soonHtml = `<div style="color:gray; font-size:0.7em;"><i>Soon ${server.soonNames.join("&nbsp;&middot;&nbsp;")}</i></div>`;
        }

        if (!footerHtml && !byeHtml && !nationsHtml && !soonHtml) return '';
        
        return `<div style="text-align:center; line-height:1.1;">${footerHtml}${byeHtml}${nationsHtml}${soonHtml}</div>`;
    }

    function renderMusician(client) {
        let sizeStr = client.name && client.name.length > 10 ? "-1" : "+0";
        let arrivalClass = client.isNewArrival ? " just-arrived" : "";
        let mId = getMusicianId(client);
        
        let instrumentDisplay = getInstrumentDisplay(client.instrument);
        let hashClass = client.hash ? ` ${client.hash}` : "";

        let html = `<div class="musician-container" id="${mId}" style="max-height: 50px; overflow: hidden; transition: all 0.75s ease-in-out; margin-bottom: 0px;">`;
        
        html += `<span class="musician${arrivalClass}${hashClass}">`;
        
        html += `<font size='${sizeStr}'><b>${client.name}</b> ${instrumentDisplay}</font>`;
        html += `</span></div>`;
        return html;
    }
    
    function createServerElement(server) {
        const serverDiv = document.createElement('div');
        serverDiv.id = getServerId(server);
        serverDiv.className = 'server-card';
        serverDiv.style.position = 'relative';
        serverDiv.style.transition = 'all 0.75s ease';

        let bgColor = '';
        switch (server.zone) {
            case 'E': bgColor = '#AFFFC6'; break;
            case 'N': bgColor = '#C1F1FF'; break;
            case 'A': bgColor = '#FFF0AA'; break;
            case 'S': bgColor = '#E8D8F8'; break;
            default: bgColor = '#D9F9F9'; break;
        }
        serverDiv.style.background = bgColor;

        // --- NEW: The inner wrapper for accurate height measurements ---
        const innerDiv = document.createElement('div');
        innerDiv.className = 'server-inner';

        const headerDiv = document.createElement('div');
        headerDiv.className = 'server-header';
        headerDiv.innerHTML = renderServerHeader(server);
        
        const clientsDiv = document.createElement('div');
        clientsDiv.className = 'server-clients';
        if (server.clients) {
            server.clients.forEach(client => {
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = renderMusician(client);
                clientsDiv.appendChild(tempDiv.firstChild);
            });
        }

        const footerDiv = document.createElement('div');
        footerDiv.className = 'server-footer';
        footerDiv.style.marginTop = '0.25rem';
        footerDiv.innerHTML = renderServerFooter(server);

        // Append to inner wrapper
        innerDiv.appendChild(headerDiv);
        innerDiv.appendChild(clientsDiv);
        innerDiv.appendChild(footerDiv);

        // Append wrapper to main card
        serverDiv.appendChild(innerDiv);

        cardHeightObserver.observe(serverDiv);

        return serverDiv;
    }

    function optimizeGhostPlacement(ghost, grid, idealData) {
        if (!idealData) return;
        
        let nodes = Array.from(grid.children);
        let ghostIndex = nodes.indexOf(ghost);
        if (ghostIndex === -1) return;

        let idealMap = {};
        idealData.forEach((srv, i) => {
            idealMap[getServerId(srv)] = i;
        });

        let easternCandidate = null;
        let easternIndex = -1;
        let southernCandidate = null;
        let southernIndex = -1;
        
        let gRect = ghost.getBoundingClientRect();
        
        for (let i = ghostIndex + 1; i < nodes.length; i++) {
            let node = nodes[i];
            if (node && !node.classList.contains('ghost-card')) {
                let nRect = node.getBoundingClientRect();
                
                if (!easternCandidate && Math.abs(gRect.top - nRect.top) < 20 && nRect.left > gRect.left) {
                    easternCandidate = node;
                    easternIndex = i;
                }
                
                if (!southernCandidate && Math.abs(gRect.left - nRect.left) < 20 && nRect.top > gRect.top) {
                    southernCandidate = node;
                    southernIndex = i;
                }
                
                if (easternCandidate && southernCandidate) break;
            }
        }

        if (!easternCandidate && !southernCandidate) return;

        function calcError(swapIdx) {
            let err = 0;
            for (let i = 0; i < nodes.length; i++) {
                let id = nodes[i].id;
                if (i === ghostIndex) id = nodes[swapIdx].id;
                else if (i === swapIdx) continue;
                
                if (idealMap[id] !== undefined) {
                    err += Math.abs(i - idealMap[id]);
                }
            }
            return err;
        }

        let bestSwap = null;
        let minErr = Infinity;

        if (easternCandidate) {
            let errE = calcError(easternIndex);
            if (errE < minErr) { minErr = errE; bestSwap = easternCandidate; }
        }
        if (southernCandidate) {
            let errS = calcError(southernIndex);
            if (errS <= minErr) { minErr = errS; bestSwap = southernCandidate; } 
        }

        if (bestSwap) {
            // --- NEW: Strip old row height memory before moving! ---
            bestSwap.style.minHeight = '';
            bestSwap.dataset.lockedHeight = '0';
            
            let swapRect = bestSwap.getBoundingClientRect();
            let gRectFinal = ghost.getBoundingClientRect();
            let dx = gRectFinal.left - swapRect.left;
            let dy = gRectFinal.top - swapRect.top;

            bestSwap.style.transition = 'transform 0.6s ease';
            bestSwap.style.transform = `translate(${dx}px, ${dy}px)`;
            bestSwap.style.zIndex = '10';

            setTimeout(() => {
                const parent = ghost.parentNode;
                if (!parent) return;
                
                const t1 = document.createTextNode('');
                const t2 = document.createTextNode('');
                parent.insertBefore(t1, ghost);
                parent.insertBefore(t2, bestSwap);
                parent.insertBefore(bestSwap, t1);
                parent.insertBefore(ghost, t2);
                t1.remove();
                t2.remove();

                bestSwap.style.transition = 'none';
                bestSwap.style.transform = '';
                bestSwap.style.zIndex = '';
                
                void bestSwap.offsetWidth; 
                
                bestSwap.style.transition = 'all 0.75s ease';
            }, 600);
        }
    }

