    function getSmartNations(server) {
        if (!server.clients || server.clients.length === 0) return "";
        
        const serverCountry = server.country || "";
        let iCountryless = 0;
        let itotalpeeps = server.clients.length;
        
        server.clients.forEach(who => {
            if (who.country === "World" || !who.country || who.country.length < 2) {
                iCountryless++;
            }
        });
        
        if (iCountryless / itotalpeeps >= 0.5) return "";
        
        let fNeeded = false;
        server.clients.forEach(who => {
            if (who.country && who.country.length > 1 && who.country !== serverCountry) {
                fNeeded = true;
            }
        });
        
        if (!fNeeded) return "";
        
        let smartNationsList = [];
        server.clients.forEach(who => {
            if (who.country && who.country.length > 1 && who.country !== "World") {
                if (!smartNationsList.includes(who.country)) {
                    smartNationsList.push(who.country);
                }
            }
        });
        
        let nationsStr = smartNationsList.join(" &middot; ");
        
        if (smartNationsList.length > 2) {
            nationsStr = nationsStr.replace(/United States/g, "USA");
            nationsStr = nationsStr.replace(/United Kingdom/g, "UK");
            nationsStr = nationsStr.replace(/Hong Kong/g, "HK");
        }
        
        if (smartNationsList.length > 3) {
            nationsStr = nationsStr.replace(/ &middot; /g, " ");
        }
        
        if (nationsStr === serverCountry) return "";
        
        return nationsStr;
    }

    function getInstrumentDisplay(instrument) {
        if (!instrument) return "";
        
        if (instrument === "Electric Guitar") return "⚡🎸";
        if (instrument === "Bass Guitar") return "<i>Bass</i> 🎸";
        if (instrument.toLowerCase().indexOf("guitar vocal") !== -1) return "🎸 <i>Vocal</i>";

        if (instrumentEmojis[instrument]) {
            return instrumentEmojis[instrument];
        }

        return `<i>${instrument}</i>`;
    }

    function getMusicianId(client, serverId, occurrence = 0) {
        return 'm-' + serverId + '-' + btoa(unescape(encodeURIComponent((client.name || '') + (client.country || '')))).replace(/=/g, '') + '-' + occurrence;
    }

    function getServerId(server) {
        return 's-' + server.serverIpAddress.replace(/\./g, '-') + '-' + server.serverPort;
    }

    function ensureNoShrink(el) {
        if (!el) return;
        const inner = el.querySelector('.server-inner');
        if (!inner) return;
        
        // Change this from 14 to 6 so it matches the ResizeObserver math perfectly
        const contentHeight = inner.offsetHeight + 6; 
        const lockedHeight = parseFloat(el.dataset.lockedHeight) || 0;
        
        if (contentHeight > lockedHeight) {
            el.dataset.lockedHeight = contentHeight;
            el.style.minHeight = contentHeight + 'px';
        }
    }

    function renderServerHeader(server) {
        let html = `<center>`;
        html += `<a href='https://jamulus.live/jamgroup-map.html?server=${server.serverIpAddress}:${server.serverPort}' target='_blank' style='position:absolute; right:5px; top:5px; z-index:10; text-decoration:none; font-size:1.5em; cursor:pointer; opacity:0; transition:opacity 0.2s;' onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0'">👀</a>`;
        
        if (server.name) html += `${server.name}<br>`;
        if (server.city) html += `<b>${server.city}</b><br>`;
        
        let cat = server.category || "";
        cat = cat.replace("Genre ", "").replace(" ", "&nbsp;");
        if (cat) html += `<font size='-1'>${cat}</font><br>`;
        
        if (server.jamStatusHtml) {
            html += `${server.jamStatusHtml}<br>`;
        }

        if (server.newServerHtml) {
            html += `${server.newServerHtml}<br>`;
        }
        
        if (server.listenHtml) {
            html += `${server.listenHtml}`;
        }
        
        html += `</center>`;
        return html;
    }

    function renderServerFooter(server) {
        let footerHtml = '';
        if (server.serverDurationHtml) {
            footerHtml += `<div>${server.serverDurationHtml}</div>`;
        }
        
        let byeHtml = server.leaversHtml || '';

        let nationsHtml = '';
        let smartNations = (server.smartNations ? server.smartNations : getSmartNations(server));
        if (smartNations) {
            if (!navigator.userAgent.includes("Windows")) {
                smartNations = replaceCountry(smartNations);
            }
            nationsHtml = `<div style="font-size:0.7em; margin-top:0.5rem;">${smartNations}</div>`;
        }
        
        let soonHtml = server.soonHtml || '';

        if (!footerHtml && !byeHtml && !nationsHtml && !soonHtml) return '';
        
        return `<div style="text-align:center; line-height:1.1;">${footerHtml}${byeHtml}${nationsHtml}${soonHtml}</div>`;
    }

    function renderMusician(client, serverId, occurrence = 0) {
        let fontSizeStyle = client.name && client.name.length > 10 ? "font-size: 0.85em;" : "font-size: 1em;";
        let arrivalClass = client.isNewArrival ? " just-arrived" : "";
        let mId = getMusicianId(client, serverId, occurrence);
        
        let instrumentDisplay = getInstrumentDisplay(client.instrument);
        let hashClass = client.hash ? ` ${client.hash}` : "";
        
        // Creates the exact same ID used in Index.cshtml for cross-compatibility
        let clickHash = (client.name || "") + (client.country || "");

        let html = `<div class="musician-container" id="${mId}" style="max-height: 50px; overflow: hidden; transition: all 0.75s ease-in-out; margin-bottom: 0px;">`;
        
        html += `<span class="musician${arrivalClass}${hashClass}" id="${clickHash}" style="cursor: pointer;" title="Click to highlight, Ctrl-Click for green">`;
        
        html += `<span style='${fontSizeStyle}'><b>${client.name}</b> ${instrumentDisplay}</span>`;
        html += `</span></div>`;
        return html;
    }
    
    function createServerElement(server) {
        const serverDiv = document.createElement('div');
        serverDiv.id = getServerId(server);
        serverDiv.className = 'server-card';
        serverDiv.style.position = 'relative';
        serverDiv.style.transition = 'all 0.75s ease';

        let bgColor = '';
        switch (server.zone) {
            case 'E': bgColor = '#AFFFC6'; break;
            case 'N': bgColor = '#C1F1FF'; break;
            case 'A': bgColor = '#FFF0AA'; break;
            case 'S': bgColor = '#E8D8F8'; break;
            default: bgColor = '#D9F9F9'; break;
        }
        serverDiv.style.background = bgColor;

        // --- NEW: The inner wrapper for accurate height measurements ---
        const innerDiv = document.createElement('div');
        innerDiv.className = 'server-inner';

        const headerDiv = document.createElement('div');
        headerDiv.className = 'server-header';
        headerDiv.innerHTML = renderServerHeader(server);
        
        const clientsDiv = document.createElement('div');
        clientsDiv.className = 'server-clients';
        if (server.clients) {
            const counts = {};
            server.clients.forEach(client => {
                const hashKey = (client.name || "") + (client.country || "");
                counts[hashKey] = (counts[hashKey] || 0);
                const occ = counts[hashKey]++;
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = renderMusician(client, getServerId(server), occ);
                clientsDiv.appendChild(tempDiv.firstChild);
            });
        }

        const footerDiv = document.createElement('div');
        footerDiv.className = 'server-footer';
        const footerHtml = renderServerFooter(server);
        if (footerHtml !== '') {
            footerDiv.style.marginTop = '0.25rem';
        }
        footerDiv.innerHTML = footerHtml;

        // Append to inner wrapper
        innerDiv.appendChild(headerDiv);
        innerDiv.appendChild(clientsDiv);
        innerDiv.appendChild(footerDiv);

        // Append wrapper to main card
        serverDiv.appendChild(innerDiv);

        cardHeightObserver.observe(serverDiv);

        return serverDiv;
    }

function optimizeGhostPlacement(ghost, grid, idealData) {
        if (!idealData) return;

        let nodes = Array.from(grid.children);
        let ghostIndex = nodes.indexOf(ghost);
        if (ghostIndex === -1) return;

        let idealMap = {};
        idealData.forEach((srv, i) => {
            idealMap[getServerId(srv)] = i;
        });

        let easternCandidate = null, easternIndex = -1;
        let southernCandidate = null, southernIndex = -1;

        let gRect = ghost.getBoundingClientRect();

        // Forward pass: finds nearest eastern and southern neighbors only.
        // Western/northern are excluded — moving a card backward just relocates the gap.
        for (let i = ghostIndex + 1; i < nodes.length; i++) {
            let node = nodes[i];
            if (node && !node.classList.contains('ghost-card')) {
                let nRect = node.getBoundingClientRect();
                if (!easternCandidate && Math.abs(gRect.top - nRect.top) < 20 && nRect.left > gRect.left) {
                    easternCandidate = node; easternIndex = i;
                }
                if (!southernCandidate && Math.abs(gRect.left - nRect.left) < 20 && nRect.top > gRect.top) {
                    southernCandidate = node; southernIndex = i;
                }
                if (easternCandidate && southernCandidate) break;
            }
        }

        // RULE EXCEPTION: Veto vertical moves if the incoming content is taller than the target row.
        if (southernCandidate) {
            let sInner = southernCandidate.querySelector('.server-inner');
            let sContentHeight = sInner ? (sInner.offsetHeight + 6) : 0;
            if (sContentHeight > ghost.offsetHeight) {
                southernCandidate = null;
            }
        }

        if (!easternCandidate && !southernCandidate) return;

        function calcError(swapIdx) {
            let err = 0;
            for (let i = 0; i < nodes.length; i++) {
                let id = nodes[i].id;
                if (i === ghostIndex) id = nodes[swapIdx].id;
                else if (i === swapIdx) continue;

                if (idealMap[id] !== undefined) {
                    err += Math.abs(i - idealMap[id]);
                }
            }
            return err;
        }

        let bestSwap = null;
        let minErr = Infinity;

        const evaluateSwap = (candidate, idx) => {
            if (!candidate) return;
            let err = calcError(idx);
            if (err < minErr) { minErr = err; bestSwap = candidate; }
        };

        evaluateSwap(easternCandidate, easternIndex);
        evaluateSwap(southernCandidate, southernIndex);

        if (bestSwap) {
            bestSwap.style.minHeight = '';
            bestSwap.dataset.lockedHeight = '0';

            let startHeight = bestSwap.offsetHeight;
            let targetHeight = ghost.offsetHeight;

            let swapRect = bestSwap.getBoundingClientRect();
            let gRectFinal = ghost.getBoundingClientRect();
            let dx = gRectFinal.left - swapRect.left;
            let dy = gRectFinal.top - swapRect.top;

            bestSwap.style.height = startHeight + 'px';
            void bestSwap.offsetHeight;

            bestSwap.style.transition = 'transform 0.6s ease, height 0.6s ease';
            bestSwap.style.transform = `translate(${dx}px, ${dy}px)`;
            bestSwap.style.height = targetHeight + 'px';
            bestSwap.style.zIndex = '10';

            setTimeout(() => {
                const parent = ghost.parentNode;
                if (!parent) return;

                const t1 = document.createTextNode('');
                const t2 = document.createTextNode('');
                parent.insertBefore(t1, ghost);
                parent.insertBefore(t2, bestSwap);
                parent.insertBefore(bestSwap, t1);
                parent.insertBefore(ghost, t2);
                t1.remove();
                t2.remove();

                bestSwap.style.transition = 'none';
                bestSwap.style.transform = '';
                bestSwap.style.zIndex = '';
                bestSwap.style.height = '';

                void bestSwap.offsetWidth;

                bestSwap.style.transition = 'all 0.75s ease';
            }, 600);
        }
    }

    async function evaluateAndSwapForAdd(firstGhost, grid, idealData, newServerId) {
        if (!idealData) return firstGhost;

        let nodes = Array.from(grid.children);
        let ghostIndex = nodes.indexOf(firstGhost);
        if (ghostIndex === -1) return firstGhost;

        let idealMap = {};
        idealData.forEach((srv, i) => {
            idealMap[getServerId(srv)] = i;
        });

        let easternCandidate = null, easternIndex = -1;
        let southernCandidate = null, southernIndex = -1;
        let westernCandidate = null, westernIndex = -1;
        let northernCandidate = null, northernIndex = -1;

        let gRect = firstGhost.getBoundingClientRect();

        // Forward pass: finds nearest eastern and southern neighbors
        for (let i = ghostIndex + 1; i < nodes.length; i++) {
            let node = nodes[i];
            if (node && !node.classList.contains('ghost-card')) {
                let nRect = node.getBoundingClientRect();
                if (!easternCandidate && Math.abs(gRect.top - nRect.top) < 20 && nRect.left > gRect.left) {
                    easternCandidate = node; easternIndex = i;
                }
                if (!southernCandidate && Math.abs(gRect.left - nRect.left) < 20 && nRect.top > gRect.top) {
                    southernCandidate = node; southernIndex = i;
                }
                if (easternCandidate && southernCandidate) break;
            }
        }

        // Backward pass: finds nearest western and northern neighbors
        for (let i = ghostIndex - 1; i >= 0; i--) {
            let node = nodes[i];
            if (node && !node.classList.contains('ghost-card')) {
                let nRect = node.getBoundingClientRect();
                if (!westernCandidate && Math.abs(gRect.top - nRect.top) < 20 && nRect.left < gRect.left) {
                    westernCandidate = node; westernIndex = i;
                }
                if (!northernCandidate && Math.abs(gRect.left - nRect.left) < 20 && nRect.top < gRect.top) {
                    northernCandidate = node; northernIndex = i;
                }
                if (westernCandidate && northernCandidate) break;
            }
        }

        // RULE EXCEPTION: Veto vertical moves if the incoming content is taller than the target row.
        if (southernCandidate) {
            let sInner = southernCandidate.querySelector('.server-inner');
            let sContentHeight = sInner ? (sInner.offsetHeight + 6) : 0;
            if (sContentHeight > firstGhost.offsetHeight) {
                southernCandidate = null; // Veto the move up
            }
        }

        if (northernCandidate) {
            let nInner = northernCandidate.querySelector('.server-inner');
            let nContentHeight = nInner ? (nInner.offsetHeight + 6) : 0;
            if (nContentHeight > firstGhost.offsetHeight) {
                northernCandidate = null; // Veto the move down
            }
        }

        if (!easternCandidate && !southernCandidate && !westernCandidate && !northernCandidate) return firstGhost;

        function calcErrorForAdd(ghostGetsId, swappedIndex) {
            let err = 0;
            for (let i = 0; i < nodes.length; i++) {
                let currentId;
                if (i === ghostIndex) {
                    currentId = ghostGetsId;
                } else if (i === swappedIndex) {
                    currentId = newServerId;
                } else {
                    currentId = nodes[i].id;
                }

                if (currentId && idealMap[currentId] !== undefined) {
                    err += Math.abs(i - idealMap[currentId]);
                }
            }
            return err;
        }

        let errDirect = calcErrorForAdd(newServerId, -1);
        let minErr = errDirect;
        let bestSwap = null;

        const evaluateSwapAdd = (candidate, idx) => {
            if (!candidate) return;
            let err = calcErrorForAdd(candidate.id, idx);
            if (err < minErr) { minErr = err; bestSwap = candidate; }
        };

        evaluateSwapAdd(easternCandidate, easternIndex);
        evaluateSwapAdd(southernCandidate, southernIndex);
        evaluateSwapAdd(westernCandidate, westernIndex);
        evaluateSwapAdd(northernCandidate, northernIndex);

        if (!bestSwap) return firstGhost;

        return new Promise(resolve => {
            bestSwap.style.minHeight = '';
            bestSwap.dataset.lockedHeight = '0';

            let startHeight = bestSwap.offsetHeight;
            let targetHeight = firstGhost.offsetHeight;

            let swapRect = bestSwap.getBoundingClientRect();
            let gRectFinal = firstGhost.getBoundingClientRect();
            let dx = gRectFinal.left - swapRect.left;
            let dy = gRectFinal.top - swapRect.top;

            bestSwap.style.height = startHeight + 'px';
            void bestSwap.offsetHeight;

            bestSwap.style.transition = 'transform 0.6s ease, height 0.6s ease';
            bestSwap.style.transform = `translate(${dx}px, ${dy}px)`;
            bestSwap.style.height = targetHeight + 'px';
            bestSwap.style.zIndex = '10';

            setTimeout(() => {
                const parent = firstGhost.parentNode;
                if (!parent) {
                    resolve(firstGhost);
                    return;
                }

                const t1 = document.createTextNode('');
                const t2 = document.createTextNode('');
                parent.insertBefore(t1, firstGhost);
                parent.insertBefore(t2, bestSwap);
                parent.insertBefore(bestSwap, t1);
                parent.insertBefore(firstGhost, t2);
                t1.remove();
                t2.remove();

                bestSwap.style.transition = 'none';
                bestSwap.style.transform = '';
                bestSwap.style.zIndex = '';
                bestSwap.style.height = '';

                void bestSwap.offsetWidth;
                bestSwap.style.transition = 'all 0.75s ease';

                resolve(firstGhost);
            }, 600);
        });
    }

    async function executeAction(action, newData) {
        const grid = document.getElementById('client-grid');
        
if (action.type === 'replace_server') {
            const el = document.getElementById(action.removeId);
            const newEl = createServerElement(action.addServer);
            if (el) {
                // 1. The Wind-Up: Elevate, glow, and spin 2.25 times (810 degrees)
                el.style.zIndex = '100'; // Bring to front so it doesn't clip neighboring cards
                el.style.transition = 'transform 0.6s cubic-bezier(0.55, 0.085, 0.68, 0.53), filter 0.6s ease-in';
                el.style.transform = 'perspective(1000px) scale(1.1) rotateY(810deg)';
                el.style.filter = 'brightness(1.5) blur(1px)';

                setTimeout(() => {
                    if (el.parentNode === grid) {
                        grid.replaceChild(newEl, el);
                        
                        // 2. The Swap: Start the new card perfectly edge-on (-90 deg) to continue the momentum
                        newEl.style.zIndex = '100';
                        newEl.style.transition = 'none';
                        newEl.style.opacity = '1';
                        newEl.style.transform = 'perspective(1000px) scale(1.1) rotateY(-90deg)';
                        newEl.style.filter = 'brightness(1.5) drop-shadow(0 0 20px gold)';
                        void newEl.offsetWidth; // Force browser reflow
                        
                        // 3. The Flourish: Snap into place with a slight physical "bounce" (ease-out-back)
                        newEl.style.transition = 'transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.5s ease-out';
                        newEl.style.transform = 'perspective(1000px) scale(1) rotateY(0deg)';
                        newEl.style.filter = 'brightness(1) drop-shadow(0 0 0 transparent)';
                        
                        // Clean up inline styles once finished
                        setTimeout(() => {
                            newEl.style.filter = '';
                            newEl.style.zIndex = '';
                        }, 500);
                    }
                }, 600); // Wait exactly for the edge-on moment (600ms)
            } else {
                // Fallback if the old element isn't in the DOM for some reason
                newEl.style.transition = 'none';
                newEl.style.opacity = '0';
                newEl.style.transform = 'scale(1.05)';
                newEl.style.filter = 'brightness(1.5) drop-shadow(0 0 10px white)';
                grid.appendChild(newEl);
                void newEl.offsetWidth;
                
                newEl.style.transition = 'all 0.75s ease-in';
                newEl.style.opacity = '1';
                newEl.style.transform = 'scale(1)';
                newEl.style.filter = 'brightness(1) drop-shadow(0 0 0 white)';
                
                setTimeout(() => newEl.style.filter = '', 750);
            }
        }
        else if (action.type === 'remove_server') {
            const el = document.getElementById(action.id);
            if (el) {
                el.style.transition = 'all 0.75s ease-out';
                el.style.opacity = '0';
                el.style.transform = 'translateY(-20px) scale(0.95)';
                el.style.filter = 'blur(4px)';
                
                setTimeout(() => {
                    if (el.parentNode !== grid) return;

                    const ghost = document.createElement('div');
                    ghost.className = 'server-card ghost-card';
                    ghost.style.visibility = 'hidden'; 
                    ghost.id = 'ghost-' + Date.now();
                    ghost.style.order = el.style.order;
                    el.replaceWith(ghost);

                    optimizeGhostPlacement(ghost, grid, newData);

                }, 750); 
            }
        }
        else if (action.type === 'add_server') {
            const el = createServerElement(action.server);

            el.style.transition = 'none';
            el.style.opacity = '0';
            el.style.transform = 'scale(1.05)';
            el.style.filter = 'brightness(1.5) drop-shadow(0 0 10px white)';

            // --- THE FIX: Look for a ghost card and evaluate the 3-way placement ---
            let firstGhost = grid.querySelector('.ghost-card');
            if (firstGhost) {
                const newServerId = getServerId(action.server);
                // Pause the queue, measure options, and animate the swap if needed
                firstGhost = await evaluateAndSwapForAdd(firstGhost, grid, newData, newServerId);
                firstGhost.replaceWith(el);
            } else {
                grid.appendChild(el);
            }
            
            void el.offsetWidth;
            
            el.style.transition = 'all 0.75s ease-in';
            el.style.opacity = '1';
            el.style.transform = 'scale(1)';
            el.style.filter = 'brightness(1) drop-shadow(0 0 0 white)';
            
            setTimeout(() => el.style.filter = '', 750);
        }
        else if (action.type === 'remove_musician') {
            const el = document.getElementById(action.mId);
            if (el) {
                const serverEl = el.closest('.server-card');
                ensureNoShrink(serverEl);

                el.style.transition = 'all 0.75s ease-out';
                el.style.opacity = '0';
                el.style.transform = 'translateY(-10px) scale(0.9)';
                el.style.filter = 'blur(2px)';
                el.style.letterSpacing = '1px';
                
                el.style.maxHeight = '0px';
                el.style.marginBottom = '0px';
                
                setTimeout(() => el.remove(), 750);
            }
        }
        else if (action.type === 'add_musician') {
            const serverEl = document.getElementById(action.serverId);
            if (serverEl) {
                const clientsDiv = serverEl.querySelector('.server-clients');
                if (clientsDiv) {
                    const tempDiv = document.createElement('div');
                    tempDiv.innerHTML = renderMusician(action.client, action.serverId, action.occurrence);
                    const el = tempDiv.firstChild;
                    
                    el.style.transition = 'none';
                    el.style.opacity = '0';
                    el.style.transform = 'scale(1.1)';
                    
                    el.style.maxHeight = '0px';
                    el.style.marginBottom = '0px';
                    el.style.textShadow = '0 0 10px rgba(255,255,255,0.8), 0 0 20px rgba(255,255,255,0.8)';
                    
                    clientsDiv.appendChild(el);
                    void el.offsetWidth;
                    
                    el.style.transition = 'all 0.75s ease-in';
                    el.style.opacity = '1';
                    el.style.transform = 'scale(1)';
                    el.style.maxHeight = '50px'; 
                    el.style.marginBottom = '2px';
                    el.style.textShadow = '0 0 0px rgba(255,255,255,0)';
                    
                    setTimeout(() => el.style.textShadow = '', 750);
                }
            }
        }
        else if (action.type === 'migrate_musician') {
            const el = document.getElementById(action.oldId);
            const toServerEl = document.getElementById(action.toServer);
            if (el && toServerEl) {
                el.id = action.newId; // UPDATE ID TO NEW SERVER'S DOM ID
                const fromServerEl = el.closest('.server-card');
                ensureNoShrink(fromServerEl);

                const clientsDiv = toServerEl.querySelector('.server-clients');
                if (clientsDiv) {
                    const firstRect = el.getBoundingClientRect();
                    
                    // 1. Create the spacer to hold the gap on the origin server
                    const oldSpacer = document.createElement('div');
                    oldSpacer.style.height = el.offsetHeight + 'px';
                    oldSpacer.style.marginBottom = '2px';
                    el.parentNode.insertBefore(oldSpacer, el);
                    
                    // 2. Delay the collapse until AFTER the musician has landed
                    setTimeout(() => {
                        // Now start the collapse animation
                        oldSpacer.style.transition = 'height 0.75s ease-in-out, margin-bottom 0.75s ease-in-out';
                        oldSpacer.style.height = '0px';
                        oldSpacer.style.marginBottom = '0px';
                        
                        // 3. Remove from DOM after collapse finishes
                        setTimeout(() => oldSpacer.remove(), 750);
                    }, 750);

                    // Move the element in the DOM
                    clientsDiv.appendChild(el);
                    
                    // Calculate the translation to fake the start position
                    const lastRect = el.getBoundingClientRect();
                    const invertX = firstRect.left - lastRect.left;
                    const invertY = firstRect.top - lastRect.top;
                    
                    el.style.transition = 'none';
                    el.style.transform = `translate(${invertX}px, ${invertY}px)`;
                    el.style.zIndex = '100';
                    el.style.position = 'relative';
                    
                    el.style.maxHeight = '0px';
                    el.style.marginBottom = '0px';
                    
                    void el.offsetWidth; // Force browser reflow
                    
                    // Animate the musician to their new home
                    el.style.transition = 'transform 0.75s ease-in-out, max-height 0.75s ease-in-out';
                    el.style.transform = 'translate(0, 0)';
                    el.style.maxHeight = '50px';
                    el.style.marginBottom = '2px';
                    
                    setTimeout(() => {
                        el.style.zIndex = '';
                        el.style.position = '';
                    }, 750);
                }
            }
        }
        else if (action.type === 'update_server_meta') {
            const serverEl = document.getElementById(getServerId(action.server));
            if (serverEl) {
                ensureNoShrink(serverEl);

                // Helper to smoothly update structural changes ONLY
                function animateMetaUpdate(container, newHtml) {
                    // Create a temporary element to let the browser normalize the new HTML quotes/spacing
                    const tempDiv = document.createElement('div');
                    tempDiv.innerHTML = newHtml;
                    
                    // If it is structurally identical, skip the update entirely
                    if (container.innerHTML === tempDiv.innerHTML) return;

                    // Otherwise, update it directly without the problematic height calculations
                    container.innerHTML = newHtml;
                }

                const headerDiv = serverEl.querySelector('.server-header');
                if (headerDiv) {
                    animateMetaUpdate(headerDiv, renderServerHeader(action.server));
                }
                
                const footerDiv = serverEl.querySelector('.server-footer');
                if (footerDiv) {
                    animateMetaUpdate(footerDiv, renderServerFooter(action.server));
                }
            }
        }
    }

    async function processDiff(oldData, newData) {
        const actions = [];
        const oldServers = new Map(oldData.map(s => [getServerId(s), s]));
        const newServers = new Map(newData.map(s => [getServerId(s), s]));

        const serversToRemove = [];
        const serversToAdd = [];

        for (const [id, oldSrv] of oldServers) {
            if (!newServers.has(id)) serversToRemove.push(id);
        }

        for (const [id, newSrv] of newServers) {
            if (!oldServers.has(id)) serversToAdd.push(newSrv);
        }

        while (serversToRemove.length > 0 || serversToAdd.length > 0) {
            if (serversToRemove.length > 0 && serversToAdd.length > 0) {
                const removeId = serversToRemove.shift();
                const addSrv = serversToAdd.shift();
                actions.push({ type: 'replace_server', removeId: removeId, addServer: addSrv });
            } else if (serversToRemove.length > 0) {
                const removeId = serversToRemove.shift();
                actions.push({ type: 'remove_server', id: removeId });
            } else if (serversToAdd.length > 0) {
                const addSrv = serversToAdd.shift();
                actions.push({ type: 'add_server', server: addSrv });
            }
        }

        const oldMusicians = new Map();
        oldData.forEach(s => {
            const sId = getServerId(s);
            if (s.clients && newServers.has(sId)) { // ONLY surviving servers
                const counts = {};
                s.clients.forEach(c => {
                    const hashKey = (c.name || "") + (c.country || "");
                    counts[hashKey] = (counts[hashKey] || 0);
                    const occ = counts[hashKey]++;
                    const mId = getMusicianId(c, sId, occ);
                    if (!oldMusicians.has(hashKey)) oldMusicians.set(hashKey, []);
                    oldMusicians.get(hashKey).push({ mId, serverId: sId, client: c, occurrence: occ });
                });
            }
        });

        const newMusicians = new Map();
        newData.forEach(s => {
            const sId = getServerId(s);
            if (s.clients && oldServers.has(sId)) { // ONLY surviving servers
                const counts = {};
                s.clients.forEach(c => {
                    const hashKey = (c.name || "") + (c.country || "");
                    counts[hashKey] = (counts[hashKey] || 0);
                    const occ = counts[hashKey]++;
                    const mId = getMusicianId(c, sId, occ);
                    if (!newMusicians.has(hashKey)) newMusicians.set(hashKey, []);
                    newMusicians.get(hashKey).push({ mId, serverId: sId, client: c, occurrence: occ });
                });
            }
        });

        for (const [id, newSrv] of newServers) {
            if (oldServers.has(id)) {
                actions.push({ type: 'update_server_meta', server: newSrv });
            }
        }

        const allHashKeys = new Set([...oldMusicians.keys(), ...newMusicians.keys()]);
        for (const hashKey of allHashKeys) {
            let oldList = oldMusicians.get(hashKey) || [];
            let newList = newMusicians.get(hashKey) || [];

            // 1a. PASS ONE: Exact server AND exact ID matches (Prevents occurrence cross-wiring)
            for (let i = oldList.length - 1; i >= 0; i--) {
                const oldM = oldList[i];
                const matchIndex = newList.findIndex(newM => newM.serverId === oldM.serverId && newM.mId === oldM.mId);
                if (matchIndex !== -1) {
                    // Perfect match found, no DOM ID renaming required
                    oldList.splice(i, 1);
                    newList.splice(matchIndex, 1);
                }
            }

            // 1b. PASS TWO: Fallback server matches (Handles occurrence shifts)
            for (let i = oldList.length - 1; i >= 0; i--) {
                const oldM = oldList[i];
                const matchIndex = newList.findIndex(newM => newM.serverId === oldM.serverId);
                if (matchIndex !== -1) {
                    const newM = newList[matchIndex];
                    if (oldM.mId !== newM.mId) {
                        const el = document.getElementById(oldM.mId);
                        if (el) el.id = newM.mId;
                    }
                    oldList.splice(i, 1);
                    newList.splice(matchIndex, 1);
                }
            }

            // 2. Migrations
            while (oldList.length > 0 && newList.length > 0) {
                const oldM = oldList.pop();
                const newM = newList.pop();
                actions.push({ 
                    type: 'migrate_musician', 
                    oldId: oldM.mId, 
                    newId: newM.mId,
                    fromServer: oldM.serverId, 
                    toServer: newM.serverId, 
                    client: newM.client 
                });
            }

            // 3. Removals
            for (const oldM of oldList) {
                actions.push({ type: 'remove_musician', mId: oldM.mId, serverId: oldM.serverId });
            }

            // 4. Additions
            for (const newM of newList) {
                actions.push({ type: 'add_musician', newId: newM.mId, serverId: newM.serverId, client: newM.client, occurrence: newM.occurrence });
            }
        }

        for (const action of actions) {
            await executeAction(action, newData);
            if (['add_musician', 'remove_musician', 'migrate_musician', 'add_server', 'remove_server', 'replace_server'].includes(action.type)) {
                await new Promise(r => setTimeout(r, 1200)); 
            }
        }
    }

    let lastFullRefresh = Date.now();
