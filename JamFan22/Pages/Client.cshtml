    // --- LOCAL STORAGE & HIGHLIGHT LOGIC ---
    function getTrackedPeople(collection) {
        var retrievedData = localStorage.getItem(collection);
        if (null === retrievedData) {
            var peep = [""];
            localStorage.setItem(collection, JSON.stringify(peep));
            retrievedData = localStorage.getItem(collection);
        }
        return JSON.parse(retrievedData);
    }

    function blankForRefresh() {
        var spans = document.querySelectorAll('span.musician');
        spans.forEach(span => {
            span.style.border = "";
            span.style.background = "";
            span.classList.remove("hottie-arrived"); // Clear hotties
        });
    }

    function subRefresh(collection, border, background) {
        var spans = document.querySelectorAll('span.musician');
        var people = getTrackedPeople(collection);
        var allYellows = getTrackedPeople("trackedPeople");
        var allGreens = getTrackedPeople("advancedTrackedPeople");

        spans.forEach(span => {
            var spanId = span.id;
            if (people.includes(spanId)) {
                span.style.border = border;
                span.style.background = background;
                if (!span.classList.contains("friend-arrived")) {
                    span.classList.add("friend-arrived");
                }
            } else {
                if (!allYellows.includes(spanId) && !allGreens.includes(spanId)) {
                    span.classList.remove("friend-arrived");
                }
            }
        });
    }

    document.addEventListener("click", function(event) {
        var target = event.target.closest('span.musician');
        if (!target || !target.id) return;

        var clickedId = target.id;
        var PeopleCollection = event.ctrlKey || event.metaKey ? "advancedTrackedPeople" : "trackedPeople";
        var fPureRemoval = false;

        // Check Basic List
        var people = getTrackedPeople("trackedPeople"); 
        if (people.includes(clickedId)) {
            for (var i = 0; i < people.length; i++) {
                if (people[i] === clickedId) {
                    people.splice(i, 1);
                    localStorage.setItem("trackedPeople", JSON.stringify(people));
                }
            }
            fPureRemoval = true;
        }

        // Check Advanced List
        var advPeople = getTrackedPeople("advancedTrackedPeople");
        if (advPeople.includes(clickedId)) {
            for (var i = 0; i < advPeople.length; i++) {
                if (advPeople[i] === clickedId) {
                    advPeople.splice(i, 1);
                    localStorage.setItem("advancedTrackedPeople", JSON.stringify(advPeople));
                }
            }
            fPureRemoval = true;
        }

        if (fPureRemoval) {
            refreshHighlights();
            return;
        }

        var targetList = getTrackedPeople(PeopleCollection);
        targetList.push(clickedId);
        localStorage.setItem(PeopleCollection, JSON.stringify(targetList));
        
        refreshHighlights();
    });

