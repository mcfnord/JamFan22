            if (serverEl) {
                ensureNoShrink(serverEl);

// Helper to smoothly update structural changes ONLY
function animateMetaUpdate(container, newHtml) {
    // Create a temporary element to let the browser normalize the new HTML quotes/spacing
    const tempDiv = document.createElement('div');
    tempDiv.innerHTML = newHtml;
    
    // If it is structurally identical, skip the update entirely
    if (container.innerHTML === tempDiv.innerHTML) return;

    // Otherwise, update it directly without the problematic height calculations
    container.innerHTML = newHtml;
}

                const headerDiv = serverEl.querySelector('.server-header');
                if (headerDiv) {
                    animateMetaUpdate(headerDiv, renderServerHeader(action.server));
                }
                
                const footerDiv = serverEl.querySelector('.server-footer');
                if (footerDiv) {
