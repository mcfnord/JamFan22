@page
@model JamFan22.Pages.ClientModel
@{
     ViewData["Title"] = "Jamulus.live (JSON Client)";
}

<style>
.server-header {
        background-color: rgba(0, 0, 0, 0.06); 
        margin: -0.5rem -0.5rem 0.25rem -0.5rem; 
        padding: 0.5rem 0.5rem 0.1rem 0.5rem; 
        border-top-left-radius: 1rem; 
        border-top-right-radius: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.55); /* Adds a subtle, high-contrast-safe line */
    }
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        grid-gap: 1rem;
    }

    .grid > div:hover {
        transform: scale(1.07);
        box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.3); 
        cursor: pointer; 
    }

    .grid > div {
        background: #D9F9F9; /* Fallback */
        padding: 0.5rem 0.5rem 0.25rem 0.5rem;
        border-radius: 1rem;
        font-family: Arial, Helvetica, sans-serif;
    }

    body {
        margin: 1rem;
        background-color: lightblue;
        line-height: unset;
    }
</style>

<div id="system-status" style="font-family: Arial, Helvetica, sans-serif; margin-bottom: 1rem;">
    @Html.Raw(Model.SystemStatus)
</div>

<div id="client-grid" class="grid"></div>

