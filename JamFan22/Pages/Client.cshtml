    async function processDiff(oldData, newData) {
        const actions = [];
        const oldServers = new Map(oldData.map(s => [getServerId(s), s]));
        const newServers = new Map(newData.map(s => [getServerId(s), s]));

        const serversToRemove = [];
        const serversToAdd = [];

        for (const [id, oldSrv] of oldServers) {
            if (!newServers.has(id)) serversToRemove.push(id);
        }

        for (const [id, newSrv] of newServers) {
            if (!oldServers.has(id)) serversToAdd.push(newSrv);
        }

        while (serversToRemove.length > 0 || serversToAdd.length > 0) {
            if (serversToRemove.length > 0 && serversToAdd.length > 0) {
                const removeId = serversToRemove.shift();
                const addSrv = serversToAdd.shift();
                actions.push({ type: 'replace_server', removeId: removeId, addServer: addSrv });
            } else if (serversToRemove.length > 0) {
                const removeId = serversToRemove.shift();
                actions.push({ type: 'remove_server', id: removeId });
            } else if (serversToAdd.length > 0) {
                const addSrv = serversToAdd.shift();
                actions.push({ type: 'add_server', server: addSrv });
            }
        }

        const oldMusicians = new Map();
        oldData.forEach(s => {
            if (s.clients) {
                s.clients.forEach(c => oldMusicians.set(getMusicianId(c), { client: c, serverId: getServerId(s) }));
            }
        });

        const newMusicians = new Map();
        newData.forEach(s => {
            if (s.clients) {
                s.clients.forEach(c => newMusicians.set(getMusicianId(c), { client: c, serverId: getServerId(s) }));
            }
        });

        for (const [mId, oldM] of oldMusicians) {
            if (!newMusicians.has(mId)) {
                if (newServers.has(oldM.serverId)) {
                    actions.push({ type: 'remove_musician', mId: mId, serverId: oldM.serverId });
                }
            } else {
                const newM = newMusicians.get(mId);
                if (oldM.serverId !== newM.serverId) {
                    if (newServers.has(oldM.serverId)) {
                        if (oldServers.has(newM.serverId)) {
                            actions.push({ type: 'migrate_musician', mId: mId, fromServer: oldM.serverId, toServer: newM.serverId, client: newM.client });
                        } else {
                            actions.push({ type: 'remove_musician', mId: mId, serverId: oldM.serverId });
                        }
                    } 
                    else {
                        if (oldServers.has(newM.serverId)) {
                            actions.push({ type: 'add_musician', mId: mId, serverId: newM.serverId, client: newM.client });
                        }
                    }
                }
            }
        }

        for (const [mId, newM] of newMusicians) {
            if (!oldMusicians.has(mId)) {
                if (oldServers.has(newM.serverId)) { 
                    actions.push({ type: 'add_musician', mId: mId, serverId: newM.serverId, client: newM.client });
                }
            }
        }

        for (const [id, newSrv] of newServers) {
            if (oldServers.has(id)) {
                actions.push({ type: 'update_server_meta', server: newSrv });
            }
        }

        for (const action of actions) {
            await executeAction(action, newData);
            if (['add_musician', 'remove_musician', 'migrate_musician', 'add_server', 'remove_server', 'replace_server'].includes(action.type)) {
                await new Promise(r => setTimeout(r, 1200)); 
            }
        }
    }

    let lastFullRefresh = Date.now();
    let ipDerivedLoginHash = null;

    function getCurrentUserHash() {
        const explicitHash = localStorage.getItem("loginHash");
        if (explicitHash) {
            if (document.getElementsByClassName(explicitHash).length > 0) {
                return explicitHash;
            }
        }
        if (ipDerivedLoginHash) {
            return ipDerivedLoginHash;
        }
        return null;
    }

    function refreshHighlights() {
        const allCards = document.getElementsByClassName("server-card");
        for(let i=0; i<allCards.length; i++) {
            allCards[i].style.border = "";
        }

        const loginHash = getCurrentUserHash();
        if (loginHash) {
            const meElements = document.getElementsByClassName(loginHash);
            if (meElements.length > 0) {
                for (let i = 0; i < meElements.length; i++) {
                    const serverCard = meElements[i].closest('.server-card');
                    if (serverCard) {
                        serverCard.style.border = "thick solid SteelBlue";
                    }
                }
            }
        }
    }

    async function fetchAndRender() {
        if (isAnimating) return;

        try {
            const response = await fetch('/api');

            const systemStatus = response.headers.get("X-System-Status");
            if (systemStatus !== null) {
                const statusDiv = document.getElementById("system-status");
                if (statusDiv) {
                    statusDiv.innerHTML = systemStatus;
                }
            }

            const headerHash = response.headers.get("X-IP-Derived-Hash");
            if (headerHash) {
                ipDerivedLoginHash = headerHash;
            }

            let data = await response.json();
            
            if (Array.isArray(data)) {
                data.forEach(server => {
                    if (server.clients) {
                        server.clients = server.clients.filter(client => {
                            if (!client.name || !client.instrument) return true;
                            if (client.name.toLowerCase().includes('obby') && client.instrument === 'Streamer') {
                                return false;
                            }
                            return true;
                        });
                    }
                });
            }

            const now = Date.now();
            if (currentData.length === 0 || now - lastFullRefresh > 480000) {
                const grid = document.getElementById('client-grid');
                grid.innerHTML = '';
                data.forEach(server => {
                    grid.appendChild(createServerElement(server));
                });
                currentData = data;
                lastFullRefresh = now;
            } else {
                isAnimating = true;
                await processDiff(currentData, data);
                currentData = data;
                isAnimating = false;
            }

            refreshHighlights();
            
        } catch(e) {
            console.error("Failed to fetch API:", e);
            isAnimating = false;
        }
    }

    fetchAndRender();
    setInterval(fetchAndRender, 20000);
</script>