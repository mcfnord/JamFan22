    // Fetch the hotties for the current user
    async function fetchHotties() {
        const loginHash = getCurrentUserHash();
        if (!loginHash) return;
        
        try {
            const response = await fetch('/hotties/' + encodeURIComponent(loginHash));
            if (response.ok) {
                activeHotties = await response.json();
                refreshHighlights(); 
            }
        } catch (e) {
            console.error("Failed to fetch hotties:", e);
        }
    }

    // OBSERVER: The "High-Water Mark" using Intrinsic Content Height
    const cardHeightObserver = new ResizeObserver(entries => {
        const grid = document.getElementById('client-grid');
        if (!grid) return;
        
        // Grab all real cards to evaluate global state
        const allCards = Array.from(grid.querySelectorAll('.server-card:not(.ghost-card)'));
        
        // Check if we're in a single-column layout (Mobile)
        let isSingleColumn = true;
        if (allCards.length > 1) {
            // If the first two cards share the same top offset, there are multiple columns
            if (allCards[0].getBoundingClientRect().top === allCards[1].getBoundingClientRect().top) {
                isSingleColumn = false;
            }
        }
        
        // Find the absolute maximum locked height across ALL cards
        let maxLockedHeight = 0;
        allCards.forEach(c => {
            const lh = parseFloat(c.dataset.lockedHeight) || 0;
            if (lh > maxLockedHeight) maxLockedHeight = lh;
        });

        for (let entry of entries) {
            const card = entry.target;
            const inner = card.querySelector('.server-inner');
            if (!inner) continue;
            
            // Measure the inside wrapper + 6px to account for the new smaller card padding
            const contentHeight = inner.offsetHeight + 6; 
            const lockedHeight = parseFloat(card.dataset.lockedHeight) || 0;
            
            // Exception: Is this the largest tile of them all?
            const isLargestTile = (lockedHeight > 0 && lockedHeight >= maxLockedHeight);
            
            if (isSingleColumn) {
                // Mobile: never lock heights, let cards size naturally
                card.style.minHeight = '';
                card.dataset.lockedHeight = '0';
            } else if (isLargestTile) {
                // Allow shrinking: sync the locked height down to the new smaller content height
                if (contentHeight !== lockedHeight) {
                    card.dataset.lockedHeight = contentHeight;
                    card.style.minHeight = contentHeight + 'px';
                }
            } else {
                // Normal High-water mark logic: only allow growing
                if (contentHeight > lockedHeight) {
                    card.dataset.lockedHeight = contentHeight;
                    card.style.minHeight = contentHeight + 'px';
                }
            }
        }
    });

